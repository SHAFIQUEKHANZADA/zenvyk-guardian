# ─────────────────────────────────────────────────────────────
# Zenvyk Guardian Web — environment variables
# Copy this file to `.env.local` and fill in real values.
# In production, set these in the Vercel project settings.
# ─────────────────────────────────────────────────────────────

# Supabase — auth + database (profiles, api_keys)
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only, NEVER exposed to the browser.
# Used for privileged server actions if needed. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Guardian backend (FastAPI on Railway) — provides /stats and /v1/verify
NEXT_PUBLIC_API_URL=https://zenvyk-guardian.up.railway.app
